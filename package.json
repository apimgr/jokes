{
  "name": "jokes-api",
  "version": "1.0.0",
  "description": "Comprehensive JOKES API with thousands of jokes across multiple categories",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "export JOKES_API_URL=http://$HOSTNAME:3009 NODE_ENV=production; node src/server.js",
    "test": "curl -q -LSsf http://localhost:3009/healthz | jq . || exit",
    "build": "docker build -t jokes-api ."
  },
  "keywords": [
    "chuck-norris",
    "jokes",
    "api",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^6.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
